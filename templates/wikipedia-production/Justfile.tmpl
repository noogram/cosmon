# <CHANGE_ME_PROJECT_NAME> — wikipedia-production mission
#
# Absorbed from wiki3 colony (Frank ENS seminar, 2026-04-13).
# Replace sentinels before use:
#   <CHANGE_ME_PROJECT_ID>   → your .cosmon/config.toml project_id
#   <CHANGE_ME_PROJECT_NAME> → short human name for the project
#
#   just mission     Launch or resume the mission (idempotent)
#   just status      Ensemble snapshot
#   just peek        Live fractal TUI
#   just clean       Kill tmux server (nuclear)

set shell := ["bash", "-euc"]

# ─── Mission ────────────────────────────────────────────────────────

# Launch OR resume the mission — idempotent
mission:
    #!/usr/bin/env bash
    set -euo pipefail
    [ -d .git ] || { echo "ERROR: not a git repo"; exit 1; }
    [ -d .cosmon ] || { echo "ERROR: .cosmon missing — run cs init first"; exit 1; }
    MISSION=$(cs --json observe 2>/dev/null | jq -r '[.[] | select(.id | startswith("mission-"))] | last | .id' 2>/dev/null || true)
    if [ -z "$MISSION" ] || [ "$MISSION" = "null" ]; then
      echo -e "\033[1;36m══ NUCLEATE MISSION ══\033[0m"
      MISSION=$(cs --json nucleate mission-controller \
        --var fleet_template=fleet.toml \
        --var goal="$(cat MISSION.md)" | jq -r '.id')
      echo -e "\033[1;32m✓ Mission: $MISSION\033[0m\n"
    else
      echo -e "\033[1;36m══ RESUME $MISSION ══\033[0m"
    fi
    echo -e "\033[1;36m══ EXECUTE ══\033[0m"
    echo -e "\033[0;90mCtrl-C to pause, just mission to resume\033[0m\n"
    cs run "$MISSION" --poll-interval 10

# Snapshot ensemble state
status:
    #!/usr/bin/env bash
    echo -e "\033[1;36m══ ENSEMBLE ══\033[0m"
    cs ensemble
    echo ""
    echo -e "\033[1;36m══ WIKI OUTPUTS ══\033[0m"
    ls wiki/ 2>/dev/null || echo "  (empty)"

# Live fractal TUI over the fleet
peek:
    cs peek

# ─── Cleanup (nuclear) ──────────────────────────────────────────────

# Kill all project tmux sessions — last resort
clean:
    tmux -L <CHANGE_ME_PROJECT_ID> kill-server 2>/dev/null || true
